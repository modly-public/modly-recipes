    "smart_channels.tempVoiceTriggerId": "{channel:tempvoice-trigger}",
    "smart_channels.tempTextChannels": false,
    "smart_channels.maxConcurrent": 50,
    "smart_channels.archiveAfterIdleMin": 30
  },
  "content": [],
  "dependencies": {
    "roles": [],
    "channels": [
      "{channel:tempvoice-cat}",
      "{channel:tempvoice-trigger}"
    ]
  }
}
