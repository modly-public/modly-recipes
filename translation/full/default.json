    "translation.fallbackLanguage": "en",
    "translation.allowedRoleId": "{role:member}",
    "translation.maxLengthChars": 2000,
    "translation.cooldownSec": 5,
    "translation.contextWindow": 5
  },
  "content": [],
  "dependencies": {
    "roles": [
      "{role:member}"
    ],
    "channels": []
  }
}
