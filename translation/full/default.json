{
  "schemaVersion": 1,
  "kind": "module-export",
  "module": "translation",
  "name": "Translation \u2014 default",
  "description": "Per-channel auto-translate plus on-demand /translate.",
  "settings": {
    "translation.enabled": true,
    "translation.autoTranslateChannels": [],
    "translation.languages": [
      "en",
      "es",
      "fr",
      "de",
      "ja",
      "pt"
