{
  "schemaVersion": 1,
  "kind": "module-export",
  "module": "appeal-portal",
  "name": "Appeal portal \u2014 default",
  "description": "Public appeal form, mods review, decisions logged.",
  "settings": {
    "appeal_portal.enabled": true,
    "appeal_portal.publicUrl": true,
    "appeal_portal.maxAppealsPerUser": 1,
    "appeal_portal.cooldownDays": 30,
    "appeal_portal.reviewChannelId": "{channel:appeals}",
    "appeal_portal.reviewerRoleId": "{role:mods}",
    "appeal_portal.notifyChannelId": "{channel:mod-log}",
    "appeal_portal.dmDecision": true,
    "appeal_portal.requireBanReason": true,
    "appeal_portal.requireExplanation": true,
    "appeal_portal.minExplanationLength": 100,
    "appeal_portal.questionCount": 3,
    "appeal_portal.allowAttachments": true,
    "appeal_portal.allowedFileTypes": [
      "png",
      "jpg",
      "pdf"
    ],
    "appeal_portal.maxFileSize": 5242880,
    "appeal_portal.threadPerAppeal": true,
    "appeal_portal.autoArchiveDays": 30,
    "appeal_portal.allowAnonymous": false,
    "appeal_portal.captchaRequired": true,
    "appeal_portal.applyDecisionAutomatically": true,
    "appeal_portal.appealRoleOnSubmit": "{role:appellant}",
    "appeal_portal.brandColor": 4886754,
    "appeal_portal.allowedLocales": [
      "en"
    ]
  },
  "content": [],
  "dependencies": {
    "roles": [
      "{role:mods}",
      "{role:appellant}"
    ],
    "channels": [
      "{channel:appeals}",
      "{channel:mod-log}"
    ]
  }
}
