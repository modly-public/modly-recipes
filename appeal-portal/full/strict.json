{
  "schemaVersion": 1,
  "kind": "module-export",
  "module": "appeal-portal",
  "name": "Appeal portal \u2014 strict",
  "description": "One appeal per ban, captcha, 90-day cooldown, manual decision required.",
  "settings": {
    "appeal_portal.enabled": true,
    "appeal_portal.publicUrl": true,
    "appeal_portal.maxAppealsPerUser": 1,
    "appeal_portal.cooldownDays": 90,
    "appeal_portal.reviewChannelId": "{channel:appeals}",
    "appeal_portal.reviewerRoleId": "{role:senior-mods}",
    "appeal_portal.minExplanationLength": 250,
    "appeal_portal.questionCount": 5,
    "appeal_portal.captchaRequired": true,
    "appeal_portal.applyDecisionAutomatically": false,
    "appeal_portal.allowAnonymous": false
  },
  "content": [],
  "dependencies": {
    "roles": [
      "{role:senior-mods}"
    ],
    "channels": [
      "{channel:appeals}"
    ]
  }
}
