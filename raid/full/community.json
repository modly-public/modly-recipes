  "settings": {
    "raid.enabled": true,
    "raid.joinWindowSec": 30,
    "raid.joinThreshold": 20,
    "raid.action": "alert",
    "raid.alertChannelId": "{channel:mod-log}",
    "raid.alertRoleId": "{role:mods}",
    "raid.minAccountDays": 0,
    "raid.scoreThreshold": 70,
    "raid.captchaOnTrip": false,
    "raid.lockChannelsOnTrip": false,
    "raid.dmJoiners": false,
    "raid.dryRun": false
  },
  "content": [],
  "dependencies": {
    "roles": [
      "{role:mods}"
    ],
    "channels": [
      "{channel:mod-log}"
    ]
  }
}
