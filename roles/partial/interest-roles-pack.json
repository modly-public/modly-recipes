      "options": [
        {
          "label": "art",
          "roleId": "{role:interest-art}"
        },
        {
          "label": "music",
          "roleId": "{role:interest-music}"
        },
        {
          "label": "tech",
          "roleId": "{role:interest-tech}"
        },
        {
          "label": "gaming",
          "roleId": "{role:interest-gaming}"
        },
        {
          "label": "books",
          "roleId": "{role:interest-books}"
        }
      ]
    }
  ],
  "dependencies": {
    "roles": [],
    "channels": []
  }
}
